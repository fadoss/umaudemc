# Constants defined from the command line in QuaTEx

umaudemc scheck dice initial dice_constant.quatex -s 1000 -d 0.1 --assign pmaude  # syntax error
umaudemc scheck dice initial dice_constant.quatex -s 1000 -d 0.1 --assign pmaude -Dn=5
umaudemc scheck dice initial dice_constant.quatex -s 1000 -d 0.1 --assign pmaude -Dn=10
